" {{{ PREFACE
"        _
" __   _(_)_ __ ___  _ __ ___
" \ \ / / | '_ ` _ \| '__/ __|
"  \ V /| | | | | | | | | (__
" (_)_/ |_|_| |_| |_|_|  \___|
"
"" ver: 0.4
"" Apr 6, 2022
"" ATTENTION: This version is for the Raspberry Pi 4 64 bit OS
"" Airline on line 181 or <S-G> 129k
"" NOTE: If changing Airline check: laststatus, ruler, showmode
" }}}

" {{{ GENERAL
set nocompatible
syntax enable
set termguicolors
set t_Co=256
set number
set relativenumber
set shortmess+=a
set shortmess+=c
set shortmess+=s
set shortmess+=w

" Airline
set noruler
set noshowmode
set laststatus=1

set expandtab
set tabstop=4
set softtabstop=4
set shiftwidth=4
set smarttab
set belloff=all
set ignorecase
set smartcase
set scrolloff=5
set clipboard^=unnamedplus
set backspace=indent,eol,start
set nowrap
set incsearch
set hidden
set showcmd
set ttyfast
set background=dark
set cursorline
set cursorlineopt=number
set encoding=utf8
set splitright
set autoindent
set copyindent
set smartindent
set showmatch
set nojoinspaces
set lazyredraw
set path+=**
set nobackup
set nowritebackup
set noundofile
set noswapfile
set foldmethod=indent
set foldtext=foldtext()
set wildmenu
set wildmode=list:longest
set completeopt=longest,menuone
" }}}

" {{{ PLUGINS
call plug#begin('~/.vim/plugged')
Plug 'yggdroot/indentline'
Plug 'nvie/vim-flake8'
Plug 'flazz/vim-colorschemes'
" Plug 'gruvbox-community/gruvbox'
Plug 'scrooloose/nerdtree'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'tpope/vim-fugitive'
Plug 'airblade/vim-gitgutter'
Plug 'christoomey/vim-tmux-navigator'
Plug 'mattn/emmet-vim'
" Plug 'valloric/youcompleteme'
call plug#end()

colorscheme deus
" }}}

" {{{ PLUGINS SETTINGS
" nnoremap ,f :NERDTreeFocus<CR>
nnoremap ,f :NERDTree<CR>
let g:NERDTreeQuitOnOpen=1
let g:NERDTreeShowHidden=1
let g:NERDTreeDirArrowExpandable="+"
let g:NERDTreeDirArrowCollapsible="~"

let g:indentLine_setColors = 0
let g:indentLine_char = '|'

let g:user_emmet_mode='n'
let g:user_emmet_mode='i'
let g:user_emmet_leader_key=","
" }}}

" {{{ MAPPINGS
let mapleader=" "
inoremap kj <esc>

nnoremap <silent> <leader><leader> <C-^>

nnoremap <leader>yd y$
nnoremap <leader>r :%s/\<<c-r><c-w>\>//g<left><left>
nnoremap <leader>* :USE LEADER r

nnoremap <silent> <leader>ep 0f(ci(
nnoremap <silent> <leader>eb 0f[ci[
nnoremap <silent> <leader>er 0f{ci{

nnoremap <silent> <leader>b 0A<space>{<CR><backspace>}<Esc><S-o>

nnoremap <leader>a zt

nnoremap B ^
nnoremap E $

nnoremap <silent> <leader>t :wall!<CR>:term<CR>

nnoremap <silent> <leader>v :vs<CR><C-w>l
nnoremap <silent> <leader>s :sp<CR><C-w>j
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <leader>ll :vertical resize +2<CR>
nnoremap <leader>rr :vertical resize -2<CR>
nnoremap <leader>uu :resize +2<CR>
nnoremap <leader>dd :resize -2<CR>
" }}}

" {{{ FUNCTIONS AND AUTOCMDS
fun! TrimWhitespace()
let l:save = winsaveview()
keeppatterns %s/\s\+$//e
call winrestview(l:save)
endfun

augroup AE35_UNIT
autocmd!
autocmd BufWritePre * :call TrimWhitespace()
autocmd! BufWritePost $MYVIMRC source % | echom "Reloaded " . $MYVIMRC | redraw
augroup END

au BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif

autocmd Filetype html setlocal tabstop=2 sw=2 sts=2
autocmd Filetype c setlocal cindent cino
autocmd Filetype text setlocal wrap textwidth=79

autocmd BufWinLeave *.* mkview
autocmd BufWinEnter *.* silent loadview
" }}}

" {{{ MACROS
"" Set marker for visual block lines in Python
let @p="mamsV'aO0i# {{{'ao0i# }}}'sk$"
" Change Airline theme
let @t="0wye180ggf'pldt':w"
" Changes colorscheme
let @b=":colorscheme d"
" }}}

" {{{ FILETYPE
filetype on
filetype indent on
filetype plugin on
" }}}

