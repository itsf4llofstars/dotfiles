"
"        _
" __   _(_)_ __ ___  _ __ ___
" \ \ / / | '_ ` _ \| '__/ __|
"  \ V /| | | | | | | | | (__
" (_)_/ |_|_| |_| |_|_|  \___|
"
"
"" ver: 0.5
"" Jul 16, 2022
"" ATTENTION: This version is for the Raspberry Pi 4 64 bit OS
"" Airline on <S-g> 126k
"" NOTE: If changing Airline check: laststatus, ruler, showmode

set nocompatible
syntax on

if $TERM == "xterm-256color"
    set termguicolors
    set guioptions="!a"
    set t_Co=256
endif

set number
set numberwidth=1
set relativenumber
set shortmess+=a
set shortmess+=c
set shortmess+=s
set belloff=all
set autochdir
" set statusline=%m\ %r%{getcwd()}%h/%f\ \ \ %l:%L\ \ %c
set statusline=%m%r%h%w\ %F\ %y\ %q\ %k\ \ %c\ [%l/%L]\ %p%%\ (%n)

set expandtab
set tabstop=4
set softtabstop=4
set shiftwidth=4
set textwidth=0
set smarttab

set ignorecase
set smartcase
set clipboard^=unnamed,unnamedplus
set scrolloff=5
set backspace=indent,eol,start
set colorcolumn=80,100
set signcolumn=number
set nowrap
set incsearch
set hidden
set showcmd
set ttyfast
set background=dark
set cursorline
set cursorlineopt=number
set lazyredraw

set splitright
set autoindent
set copyindent
set smartindent
set showmatch
set nojoinspaces

set visualbell
set t_vb=

set wildmode=list:longest
set completeopt=menu,menuone,popup

filetype on
filetype indent on
filetype plugin on

set wildmenu
set path+=**

set laststatus=2
set ruler
set showmode

set foldclose=""
set foldcolumn=2
set foldenable
set foldexpr="0"
set foldignore=#
set foldlevel=5
set foldlevelstart=5
set foldmethod=indent
set foldminlines=0
set foldnestmax=20
set foldopen="block,hor,mark,percent,quickfix,serch,tag,undo"
set foldtext=foldtext()

if !isdirectory($HOME . '/.vim/backups')
    call mkdir($HOME . '/.vim/backups', 'p')
endif
set backupdir=~/.vim/backups
set backup

if !isdirectory($HOME . '/.vim/swaps')
    call mkdir($HOME . '/.vim/swaps', 'p')
endif
set directory=~/.vim/swaps
set swapfile

if has('persistent_undo')
    if !isdirectory($HOME . '/.vim/undodir')
        call mkdir($HOME . '/.vim/undodir', 'p')
    endif
    set undodir=~/.vim/undodir
    set undofile
endif

""" "" Run :PlugInstall
call plug#begin('~/.vim/plugged')
" Plug 'yggdroot/indentline'
" Plug 'nvie/vim-flake8'
" Plug 'flazz/vim-colorschemes'
Plug 'gruvbox-community/gruvbox'
" Plug 'scrooloose/nerdtree'
" Plug 'vim-airline/vim-airline'
" Plug 'vim-airline/vim-airline-themes'
" Plug 'tpope/vim-fugitive'
" Plug 'airblade/vim-gitgutter'
" Plug 'christoomey/vim-tmux-navigator'
" Plug 'mattn/emmet-vim'
" Plug 'valloric/youcompleteme'
call plug#end()

colorscheme gruvbox

" nnoremap ,f :NERDTreeFocus<CR>
" nnoremap ,f :NERDTree<CR>
" let g:NERDTreeQuitOnOpen=1
" let g:NERDTreeShowHidden=1
" let g:NERDTreeDirArrowExpandable="+"
" let g:NERDTreeDirArrowCollapsible="~"

"" INDENTLINE PLUGIN FORAMT
" let g:indentLine_setColors = 0
" let g:indentLine_char = '|'

"" Emmet plug leader change
" let g:user_emmet_mode='n'
" let g:user_emmet_mode='i'
" let g:user_emmet_leader_key=","

let mapleader=" "
let maplocalleader="\\"
inoremap kj <esc>

" Run delete in insert mode
inoremap <c-d> <Cmd>delete<cr>

nnoremap <silent> [b :bprevious<CR>
nnoremap <silent> ]b :bnext<CR>
nnoremap <silent> <leader><leader> <C-^>

nnoremap <leader>yd y$
nnoremap <leader>* :%s/\<<c-r><c-w>\>//g<left><left>

nnoremap <localleader>e :e $MYVIMRC<CR>
nnoremap <localleader>b :e $HOME/.bashrc<CR>

nnoremap <leader>a zt
nnoremap B ^
nnoremap E $

nnoremap <leader>w :write<CR>
nnoremap <leader>q :quit!<CR>
nnoremap <leader>z ZZ

nnoremap <silent> <leader>v :vs<CR><C-w>l
nnoremap <silent> <leader>s :sp<CR><C-w>j
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <leader>ll :vertical resize +2<CR>
nnoremap <leader>rr :vertical resize -2<CR>
nnoremap <leader>uu :resize +2<CR>
nnoremap <leader>dd :resize -2<CR>

"" Trims trailing whitespace on save
fun! TrimWhitespace()
let l:save = winsaveview()
keeppatterns %s/\s\+$//e
call winrestview(l:save)
endfun

" Auto Commands
augroup general
  autocmd!
  autocmd BufWritePre * :call TrimWhitespace()
  autocmd BufWritePre * mkview
  autocmd BufReadPost * loadview
  autocmd BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exe "normal! g'\"" | endif
  autocmd InsertEnter * setlocal norelativenumber
  autocmd InsertLeave * setlocal relativenumber
augroup END

augroup filetype_vim
  autocmd!
  autocmd FileType vim setlocal tabstop=2 softtabstop=2 shiftwidth=2 textwidth=0 nowrap expandtab foldmethod=marker
  autocmd Filetype vim nnoremap <buffer> <localleader>c I" <esc>
augroup END

augroup vimrc
  autocmd!
  autocmd! BufWritePost $MYVIMRC source % | echom "Reloaded " . $MYVIMRC | redraw
augroup END

augroup filetype_text
  autocmd!
  autocmd FileType text setlocal textwidth=79 wrap noexpandtab
augroup END

augroup buffers_txt
  autocmd!
  autocmd BufRead,BufNewFile *.txt :write
augroup END

augroup filetype_html
  autocmd!
  autocmd Filetype html,css setlocal tabstop=2 softtabstop=2 shiftwidth=2 textwidth=0 nowrap expandtab foldmethod=manual
  autocmd Filetype html nnoremap <buffer> <localleader>f Vatzf
augroup END

augroup buffer_html
  autocmd!
  autocmd BufWritePre,BufRead *.html :normal gg=G
augroup END

augroup filetype_py
  autocmd!
  autocmd FileType python nnoremap <buffer> <localleader>c I# <esc>
  autocmd FileType python setlocal tabstop=4 softtabstop=4 shiftwidth=4 textwidth=0 nowrap expandtab
  autocmd FileType python :iabbrev <buffer> iff if:<left>
  autocmd FileType python let @f="mamsV'aO# {{{€ýa'ao# }}}€ýa'sk$"
augroup END

augroup filetype_c_cpp
  autocmd!
  autocmd FileType c,cpp setlocal tabstop=4 softtabstop=4 shiftwidth=4 textwidth=0 nowrap expandtab
  autocmd FileType c,cpp nnoremap <buffer> <localleader>c I// <esc>
  autocmd Filetype c,cpp :iabbrev <buffer> iff if () {<cr><cr>}<esc>2k3l
  autocmd FileType c,cpp let @f="mamsV'aO// {{{€ýa'ao// }}}€ýa'sk$"
augroup END

